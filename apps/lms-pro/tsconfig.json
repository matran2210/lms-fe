{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@adapters/*": [
        "src/adapters/*"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@contexts/*": [
        "src/contexts/*"
      ],
      "@services/*": [
        "src/services/*"
      ],
      "@styles/*": [
        "src/styles/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ],
      "@assets/*": [
        "src/assets/*"
      ],
      "@i18n/*": [
        "src/i18n/*"
      ],
      "@pages/*": [
        "src/pages/*"
      ]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "src",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../../features/schedule/src/components/teacher/StudentCell.tsx",
    "../../features/schedule/src/components/teacher/StudentFilter.tsx",
    "../../features/schedule/src/components/teacher/ItemClassesByStatus.tsx",
    "../../features/schedule/src/components/teacher/MyClassFilter.tsx",
    "../../features/schedule/src/components/teacher/ChapterTestFilter.tsx",
    "../../libs/hooks/useSelectClassCode.tsx",
    "../../libs/hooks/useSelectLesson.tsx",
    "../../features/schedule/src/components/teacher/StudentsTestResultFilter.tsx",
    "../../features/schedule/src/components/teacher/NameActionCell.tsx",
    "../../features/schedule/src/components/teacher/DateActionCell.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}