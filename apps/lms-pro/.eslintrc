{
  "extends": ["next/core-web-vitals", "next", "prettier"],
  "plugins": ["import"],
  "rules": {
    "no-console": "error",
    // "no-unused-vars": "error",
    "@next/next/no-document-import-in-page": "off",
    // "import/no-unused-modules": [1, { "unusedExports": true }]
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
  },
}
