# =============================================================
# lms-test environment variables
# Chỉ gồm các biến thực sự được dùng trong app lms-test.
# Chọn 1 trong 2 môi trường bên dưới (DEV hoặc UAT) rồi điền giá trị tương ứng.
# =============================================================

# -------------------------------------------------------------
# DEV
# -------------------------------------------------------------
NEXT_PUBLIC_BASE_API_URL=https://dev-lms-be.sapp.edu.vn/api/v1
NEXT_PUBLIC_TEST_API_URL=https://dev-mock-test-be.sapp.edu.vn/api/v1
NEXT_PUBLIC_VIDEO_URL=https://customer-9amjw4bjeabflln6.cloudflarestream.com/
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-3Y71SB8L7D
NEXT_PUBLIC_GTM_ID=GTM-P6FDFP8M
NEXT_PUBLIC_SOCKET=https://dev-socket-be.sapp.edu.vn/
NEXT_PUBLIC_WEB_LMS_URL=https://dev-lms.sapp.edu.vn/
NEXT_PUBLIC_SUB_DOMAIN_TEST=http://localhost:3001

# Keycloak
NEXT_PUBLIC_KEYCLOAK_URL=https://dev-accounts.sapp.edu.vn/
NEXT_PUBLIC_KEYCLOAK_REALM=lms-dev
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=local-lms-frontend

# Sentry
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_SENTRY_NAME=sapp-tg
NEXT_PUBLIC_SENTRY_PROJECT=lms-dev-sentry

# Firebase (dùng cho push notification qua @lms/utils -> getMessagingToken)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyB12OZbgQA8VpCSAYrgytTJkUexafwiN74
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sapp-develop.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sapp-develop
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sapp-develop.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=579391570124
NEXT_PUBLIC_FIREBASE_APP_ID=1:579391570124:web:ed5e7c72474edf434bc269
NEXT_PUBLIC_FIREBASE_VAPIDKEY=BANlYjHJCUf-jXUtrRR8zXl2QytADlfN9vVUP_N_3dd3nGgH7tcIAgOcTGHRr8pyCNujwHdpVZ7DSg5SsViq5u0

