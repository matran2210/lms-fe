# LMS Test environment example
# Copy this file to `.env` and replace placeholder values for your environment.
# Do not commit real secrets or private credentials.

# App URLs
NEXT_PUBLIC_WEB_LMS_URL=http://localhost:3000
NEXT_PUBLIC_SUB_DOMAIN_TEST=http://localhost:3001
NEXT_PUBLIC_SAPP_HOMEPAGE_DOMAIN=https://sapp.edu.vn

# Backend APIs
NEXT_PUBLIC_BASE_API_URL=https://your-lms-api.example.com/api/v1
NEXT_PUBLIC_TEST_API_URL=https://your-test-api.example.com/api/v1
NEXT_PUBLIC_SOCKET=https://your-socket-api.example.com

# Keycloak
NEXT_PUBLIC_KEYCLOAK_URL=https://your-keycloak.example.com
NEXT_PUBLIC_KEYCLOAK_REALM=your-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=your-client-id

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_VAPIDKEY=your-firebase-vapid-key

# Media
NEXT_PUBLIC_VIDEO_URL=https://your-video-stream.example.com/
NEXT_PUBLIC_DECRYPT_CRYPTO_KEY=your-decrypt-key

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Sentry
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_NAME=

# Optional integrations
NEXT_PUBLIC_TINY_EDITDER_API_KEY=
NEXT_PUBLIC_FORM_ID=
NEXT_PUBLIC_PORTAL_ID=
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=

# Do not expose private OAuth client secrets with NEXT_PUBLIC_* variables.
