{
  "name": "lms-fe",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:lms-pro": "pnpm --filter ./apps/lms-pro build",
    "build:finhub": "pnpm --filter ./apps/finhub build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev:lms-pro": "pnpm --filter ./apps/lms-pro dev",
    "dev:finhub": "pnpm --filter ./apps/finhub dev",
    "prepare": "husky install",
    "lint-staged": "lint-staged",
    "gen:assets": "node scripts/generate-assets-index.js"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.21.0",
    "@typescript-eslint/parser": "^5.21.0",
    "depcheck": "^1.4.7",
    "eslint-plugin-only-warn": "^1.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "postcss-nesting": "^12.1.5",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.1",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.22.0",
  "lint-staged": {
    "**/*.ts": "eslint --fix",
    "**/*.tsx": "eslint --fix",
    "**/*.js": "eslint --fix",
    "**/*.json": "prettier --write",
    "**/*.md": "prettier --write"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.24.0",
    "@babel/runtime": "^7.26.0",
    "@eslint/js": "^8.0.0",
    "@funktechno/texthighlighter": "^2.1.2",
    "@hookform/resolvers": "^3.10.0",
    "antd": "^5.25.0",
    "critters": "^0.0.19",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.0.0",
    "lodash": "^4.17.21",
    "react-hook-form": "7.48.2",
    "react-query": "3.39.3",
    "styled-components": "^6.1.19",
    "typescript-eslint": "^8.32.0"
  }
}
