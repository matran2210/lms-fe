{
  "name": "lms-fe",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:lms-pro": "pnpm --filter ./apps/lms-pro build",
    "build:lms-finhub": "pnpm --filter ./apps/lms-finhub build",
    "build:lms-zoom": "pnpm --filter ./apps/lms-zoom build",
    "build:lms-test": "pnpm --filter ./apps/lms-test build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev:lms-pro": "pnpm --filter ./apps/lms-pro dev",
    "dev:lms-finhub": "pnpm --filter ./apps/lms-finhub dev",
    "dev:lms-zoom": "pnpm --filter ./apps/lms-zoom dev",
    "dev:lms-test": "pnpm --filter ./apps/lms-test dev",
    "start:lms-pro": "pnpm --filter ./apps/lms-pro start",
    "start:lms-finhub": "pnpm --filter ./apps/lms-finhub start",
    "start:lms-zoom": "pnpm --filter ./apps/lms-zoom start",
    "start:lms-test": "pnpm --filter ./apps/lms-test start",
    "prepare": "husky install",
    "lint-staged": "lint-staged",
    "gen:assets": "node scripts/generate-assets-index.js"
  },
  "devDependencies": {
    "@eslint/js": "^8.0.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.10.1",
    "@types/react": "18.2.21",
    "@types/react-dom": "18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.1",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "postcss-nesting": "^12.1.5",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.1",
    "typescript": "5.1.6"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@10.22.0",
  "lint-staged": {
    "**/*.ts": "eslint --fix",
    "**/*.tsx": "eslint --fix",
    "**/*.js": "eslint --fix",
    "**/*.json": "prettier --write",
    "**/*.md": "prettier --write"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.24.0",
    "@babel/runtime": "^7.26.0",
    "@eslint/js": "^8.0.0",
    "@funktechno/texthighlighter": "^2.1.2",
    "@hookform/resolvers": "^3.10.0",
    "@sapp-fe/explanation-package": "^1.5.6",
    "@sapp-fe/sapp-common-package": "^1.7.4",
    "antd": "^5.25.0",
    "critters": "^0.0.19",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.0.0",
    "lodash": "^4.17.21",
    "next": "12.3.7",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "7.48.2",
    "react-query": "3.39.3",
    "styled-components": "^6.1.19"
  }
}
