{
  "name": "next-core-project",
  "version": "1.0.0",
  "private": false,
  "author": "catfish",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint-staged": "lint-staged",
    "prepare": "husky install",
    "create-network": "docker network create my_network",
    "run:dev": "COMPOSE_DOCKER_CLI_BUILD=1 DOCKER_BUILDKIT=1 docker-compose -f docker-compose.dev.yml build --parallel && docker-compose -f docker-compose.dev.yml up",
    "run:prod": "COMPOSE_DOCKER_CLI_BUILD=1 DOCKER_BUILDKIT=1 docker-compose -f docker-compose.prod.yml build --parallel && docker-compose -f docker-compose.prod.yml up -d",
    "stop-all-running-containers": "docker kill $(docker ps -q) && docker rm $(docker ps -a -q)",
    "free-space": "docker system prune -af --volumes",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@cloudflare/stream-react": "^1.8.0",
    "@hookform/resolvers": "^3.3.2",
    "@react-native-async-storage/async-storage": "^1.19.5",
    "@reduxjs/toolkit": "^1.9.7",
    "@types/cookie": "^0.6.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.14.202",
    "axios": "^1.6.2",
    "cookie": "^0.6.0",
    "date-fns": "^2.30.0",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "next": "^12.1.6",
    "next-i18next": "^13.2.2",
    "next-redux-wrapper": "^8.1.0",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^9.3.0",
    "preview-part": "^1.1.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.20.0",
    "react-select": "^5.8.0",
    "sass": "^1.53.0",
    "sharp": "^0.30.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.3",
    "@commitlint/config-conventional": "^17.0.3",
    "@next/bundle-analyzer": "13.4.3",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.6",
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.14",
    "autoprefixer": "^10.4.16",
    "critters": "^0.0.19",
    "eslint": "7.32.0",
    "eslint-config-next": "^12.2.0",
    "eslint-config-prettier": "^8.5.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "postcss": "^8.4.31",
    "postcss-nesting": "^12.0.1",
    "prettier": "^3.0.3",
    "prettier-plugin-tailwindcss": "^0.5.6",
    "tailwindcss": "^3.3.5",
    "typescript": "^4.7.4"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,json,jsx,scss,css}": [
      "prettier --write '**/*.{js,jsx,ts,tsx,scss,css,json}'",
      "eslint --ext .js,.jsx,.ts,.tsx src --color",
      "git add ."
    ]
  },
  "browserslist": [
    "chrome 64",
    "edge 79",
    "firefox 67",
    "opera 51",
    "safari 12"
  ]
}
